# Supabase — preencher com as chaves do seu projeto (https://app.supabase.com)
# Settings → API → Project URL e Project API keys
NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<sua-anon-key>

# Service role bypassa RLS — usar APENAS em rotas server-side seguras (cron,
# admin). NUNCA commitar valor real nem expor ao cliente.
SUPABASE_SERVICE_ROLE_KEY=<sua-service-role-key>

# Vercel Cron — segredo para autorizar a rota /api/cron/snapshot.
# Gerar com: openssl rand -hex 32
CRON_SECRET=
