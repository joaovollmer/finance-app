# Supabase — preencher com as chaves do seu projeto.
# Settings → API → Project URL e Project API keys.
NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<sua-anon-key>

# Service role bypassa RLS — usar APENAS em rotas server-side seguras
# (cron, admin). NUNCA commitar valor real nem expor ao cliente.
SUPABASE_SERVICE_ROLE_KEY=<sua-service-role-key>

# Vercel Cron — segredo para autorizar a rota /api/cron/snapshot.
# Gerar com: openssl rand -hex 32
CRON_SECRET=

# Upstash Redis — rate limiting de /api/*. Crie em https://upstash.com →
# Redis Database (free tier basta). Sem essas vars, cai num limiter
# in-memory por instância (OK em dev, fraco em prod).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry — observabilidade. Crie projeto em https://sentry.io e copie o
# DSN. Sem DSN, o SDK fica no-op e nada é enviado.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Para upload de sourcemaps no build de produção (opcional):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
